# ---------- Base Image ----------
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# ---------- System Dependencies ----------
# Install essential networking tools (nmap, snmp, ping, netcat, etc.)
RUN apt-get update && apt-get install -y \
    build-essential gcc libpq-dev \
    nmap snmp net-tools iputils-ping \
    && rm -rf /var/lib/apt/lists/*

# ---------- Python Dependencies ----------
# Copy requirements first to leverage Docker cache
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ---------- Application Source ----------
COPY . .

# ---------- Ports ----------
EXPOSE 8000

# ---------- Command ----------
# Run FastAPI in dev mode with auto-reload
CMD ["uvicorn", "app.main_app:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
